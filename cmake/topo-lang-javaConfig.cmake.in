@PACKAGE_INIT@

# topo-lang-java CMake package config.
#
# Consumers do:
#     find_package(topo-lang-java CONFIG REQUIRED)
#     target_link_libraries(<tgt> PRIVATE topo::lang-java::TopoJavaAnalysis)
#
# topo-lang-java's libs PUBLIC-depend on topo-core (frontend / check /
# transpile / lsp bridge) and topo-lang (plugin framework).

include(CMakeFindDependencyMacro)

if(NOT TARGET topo::core::TopoCheck)
    find_dependency(topo-core CONFIG)
endif()
if(NOT TARGET topo::lang::TopoLang)
    find_dependency(topo-lang CONFIG)
endif()
find_dependency(nlohmann_json CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/topo-lang-javaTargets.cmake")

check_required_components(topo-lang-java)
