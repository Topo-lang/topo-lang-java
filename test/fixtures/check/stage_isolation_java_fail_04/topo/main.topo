// Three stages, multiple forward edges:
//   * stage<1> -> stage<3>
//   * stage<2> -> stage<3>
// Both are forward calls into a later stage.

namespace app {
  public:
    void run();

    type App {
      public:
        void readInput();
        void normalize();
        void writeOutput();
    }

    fn run {
        stage<1> app::App::readInput();
        stage<2> app::App::normalize();
        stage<3> app::App::writeOutput();
    }
}
