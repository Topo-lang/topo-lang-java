// Purity violation via a SINGLE-LINE method body — regression guard for the
// JavaSymbolAccessExtractor scope-leak fixed 2026-05-18 (see issue
// puritycheck-flow-form-misses-violations-non-python-hosts).
//
// `parse` has a compact one-line body `{ ... }`; before the fix its closing
// `}` was consumed before the method was detected, so `inFunction` leaked
// and `audit`'s later static write was dropped -> false PASS. `parse` and
// `audit` share stage<1> (parallel); `audit` writes static `sideLog`, which
// MUST be flagged.

namespace app {
  public:
    void run();

    type App {
      public:
        void parse();
        void audit();
    }

    fn run {
        stage<1> app::App::parse();
        stage<1> app::App::audit();
    }
}
