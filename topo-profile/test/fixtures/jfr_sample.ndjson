#   {"event_type":"jdk.ExecutionSample",
#    "ts_ns":<int>,
#    "thread":{"id":<int>,"name":"<str>"},
#    "stack":[{"class":"<C>","method":"<M>","line":<int>?}, ...],
#    "duration_ns":<int>?}
#
# Frame order: root -> leaf (jdk.jfr API default — opposite of folded).
