# Checked-in JFR-NDJSON fixture exercising the per-Pass
# profile event routing (pass_events.<PassName>[]). Mixes ordinary
# jdk.ExecutionSample sampling events with the four topo.pass.* events
# the jfr-bridge forwards stackless under a "fields" object. Proves the
# routing is additive: the ExecutionSample lines still populate the
# sampling segment while the topo.pass.* lines populate pass_events.
#
# Frame order: root -> leaf (jdk.jfr API default). Comment/blank lines
# are skipped. This is exactly the shape `topo-profile-jvm-jfr.jar`
# emits, so no JVM is needed at test time.
{"event_type":"jdk.ExecutionSample","ts_ns":1000000,"thread":{"id":1,"name":"main"},"stack":[{"class":"main.App","method":"run","line":12},{"class":"geom.Mesh","method":"compute","line":42}]}
{"event_type":"topo.pass.AdaptivePass","ts_ns":1500000,"thread":{"id":1,"name":"main"},"fields":{"method":"geom::Mesh::compute","from":"target","to":"fallback"}}
{"event_type":"jdk.ExecutionSample","ts_ns":2000000,"thread":{"id":1,"name":"main"},"stack":[{"class":"main.App","method":"run","line":12},{"class":"geom.Mesh","method":"compute","line":42}]}
{"event_type":"topo.pass.ArenaPass","ts_ns":2500000,"thread":{"id":1,"name":"main"},"fields":{"method":"geom::Mesh::solve","scope":"frame","size":65536,"phase":"open"}}
{"event_type":"topo.pass.ParallelPass","ts_ns":3000000,"thread":{"id":42,"name":"worker-0"},"fields":{"method":"geom::Mesh::solve","spawnSite":"geom::Kernel::step"}}
{"event_type":"topo.pass.PipelinePass","ts_ns":3500000,"thread":{"id":1,"name":"main"},"fields":{"method":"main::App::pipeline","topology":"load->transform->store"}}
{"event_type":"topo.pass.ArenaPass","ts_ns":4000000,"thread":{"id":1,"name":"main"},"fields":{"method":"geom::Mesh::solve","scope":"frame","size":65536,"phase":"close"}}
{"event_type":"jdk.ExecutionSample","ts_ns":4500000,"thread":{"id":42,"name":"worker-0"},"stack":[{"class":"main.Pool","method":"work","line":71},{"class":"geom.Mesh","method":"compute","line":42}]}
